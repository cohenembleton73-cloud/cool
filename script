--==================================================
-- ESP LOGIC
--==================================================
local function destroyESPForPlayer(plr)
	local d = espObjects[plr]
	if not d then return end
	if d.charConn then d.charConn:Disconnect() end
	if d.highlight then d.highlight:Destroy() end
	if d.billboard then d.billboard:Destroy() end
	espObjects[plr] = nil
end

local function createESPForPlayer(plr)
	if plr == LocalPlayer then return end
	destroyESPForPlayer(plr)

	local char = plr.Character
	local hrp = getHRP(char)
	if not char or not hrp then return end

	local d = {}
	espObjects[plr] = d

	local hl = Instance.new("Highlight")
	hl.Name = "LocalESP_Highlight"
	hl.Adornee = char
	hl.FillColor = Color3.fromRGB(255, 230, 120)
	hl.FillTransparency = 0.6
	hl.OutlineColor = Color3.fromRGB(255,255,255)
	hl.OutlineTransparency = 0
	hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
	hl.Enabled = false
	hl.Parent = screenGui
	d.highlight = hl

	local bill = Instance.new("BillboardGui")
	bill.Name = "LocalESP_Tag"
	bill.Adornee = hrp
	bill.Size = UDim2.new(0, 190, 0, 48)
	bill.StudsOffset = Vector3.new(0, 3.4, 0)
	bill.AlwaysOnTop = true
	bill.MaxDistance = 5000
	bill.Enabled = false
	bill.Parent = screenGui
	d.billboard = bill

	local bg = Instance.new("Frame")
	bg.Size = UDim2.new(1,0,1,0)
	bg.BackgroundColor3 = Color3.fromRGB(255,255,255)
	bg.BackgroundTransparency = 0.15
	bg.Parent = bill
	addCorner(bg, 10)
	addStroke(bg, COLORS.Stroke, 2)

	local nameText = createLabel(bg, plr.DisplayName, UDim2.new(1, -8, 0, 20), UDim2.new(0,4,0,2), Enum.Font.GothamBold, 13, COLORS.Text, 1)
	nameText.TextXAlignment = Enum.TextXAlignment.Center
	local infoText = createLabel(bg, "", UDim2.new(1, -8, 0, 18), UDim2.new(0,4,0,23), Enum.Font.Gotham, 12, COLORS.SubText, 1)
	infoText.TextXAlignment = Enum.TextXAlignment.Center

	d.nameText = nameText
	d.infoText = infoText

	d.charConn = plr.CharacterAdded:Connect(function()
		task.wait(0.25)
		createESPForPlayer(plr)
	end)
end

local function rebuildESP()
	for plr, _ in pairs(espObjects) do
		destroyESPForPlayer(plr)
	end
	for _, plr in ipairs(Players:GetPlayers()) do
		if plr ~= LocalPlayer then
			createESPForPlayer(plr)
		end
	end
end

local function updateESP()
	local myChar = getCharacter()
	local myHRP = getHRP(myChar)

	for _, plr in ipairs(Players:GetPlayers()) do
		if plr ~= LocalPlayer then
			if not espObjects[plr] then
				createESPForPlayer(plr)
			end

			local d = espObjects[plr]
			if d then
				local char = plr.Character
				local hum = getHumanoid(char)
				local hrp = getHRP(char)

				local alive = hum and hum.Health > 0 and hrp and char
				local withinDist = false
				local dist = nil

				if alive and myHRP then
					dist = (myHRP.Position - hrp.Position).Magnitude
					withinDist = dist <= espMaxDistance
				elseif alive then
					withinDist = true
				end

				local canShow = espEnabled and alive and withinDist

				if d.highlight then
					d.highlight.Enabled = canShow and espHighlightsEnabled
					if alive then
						d.highlight.Adornee = char
						if espUseTeamColor and plr.TeamColor then
							d.highlight.FillColor = plr.TeamColor.Color
							d.highlight.OutlineColor = Color3.fromRGB(255,255,255)
						else
							d.highlight.FillColor = Color3.fromRGB(255, 230, 120)
							d.highlight.OutlineColor = Color3.fromRGB(255,255,255)
						end
					end
				end

				if d.billboard then
					d.billboard.Enabled = canShow and espNameTagsEnabled
					if alive then
						d.billboard.Adornee = hrp
					end
				end

				if d.nameText then
					d.nameText.Text = plr.DisplayName
					d.nameText.TextColor3 = (espUseTeamColor and plr.TeamColor and plr.TeamColor.Color) or COLORS.Text
				end

				if d.infoText then
					if canShow then
						local chunks = {}

						if espShowHealth and hum then
							table.insert(chunks, ("HP %d/%d"):format(math.floor(hum.Health + 0.5), math.floor(hum.MaxHealth + 0.5)))
						end
						if espShowDistance and dist then
							table.insert(chunks, ("%dstuds"):format(math.floor(dist + 0.5)))
						end
						if #chunks == 0 then
							d.infoText.Text = "Player"
						else
							d.infoText.Text = table.concat(chunks, "  •  ")
						end
					else
						d.infoText.Text = ""
					end
				end
			end
		end
	end
end

rebuildBtn.MouseButton1Click:Connect(rebuildESP)

--==================================================
-- MOVEMENT + FLY LOGIC
--==================================================
local function applyMovementStats()
	local char = getCharacter()
	local hum = getHumanoid(char)
	if hum then
		hum.WalkSpeed = currentWalkSpeed
		hum.UseJumpPower = true
		hum.JumpPower = currentJumpPower
	end
end

local function stopFly()
	local char = getCharacter()
	local hrp = getHRP(char)
	local hum = getHumanoid(char)

	if flyBV then flyBV:Destroy() flyBV = nil end
	if flyBG then flyBG:Destroy() flyBG = nil end

	if hum then
		hum.PlatformStand = false
	end

	if hrp then
		hrp.AssemblyLinearVelocity = Vector3.new(0, hrp.AssemblyLinearVelocity.Y, 0)
	end

	flyDownBtn.Visible = false
end

local function startFly()
	local char = getCharacter()
	local hrp = getHRP(char)
	local hum = getHumanoid(char)
	if not char or not hrp or not hum then return end

	stopFly()

	hum.PlatformStand = true

	local bv = Instance.new("BodyVelocity")
	bv.Name = "LocalFlyBV"
	bv.MaxForce = Vector3.new(1e9, 1e9, 1e9)
	bv.Velocity = Vector3.zero
	bv.Parent = hrp
	flyBV = bv

	local bg = Instance.new("BodyGyro")
	bg.Name = "LocalFlyBG"
	bg.MaxTorque = Vector3.new(1e9, 1e9, 1e9)
	bg.P = 20000
	bg.CFrame = hrp.CFrame
	bg.Parent = hrp
	flyBG = bg

	flyDownBtn.Visible = true
end

local function updateFly(dt)
	if not flyEnabled then
		if flyBV or flyBG then
			stopFly()
		end
		return
	end

	local char = getCharacter()
	local hrp = getHRP(char)
	local hum = getHumanoid(char)
	if not char or not hrp or not hum then return end

	if not flyBV or not flyBG then
		startFly()
	end
	if not flyBV or not flyBG then return end

	local camCF = Camera.CFrame
	local moveDir = hum.MoveDirection
	local horizontal = Vector3.new(moveDir.X, 0, moveDir.Z)

	local upY = 0
	if hum.Jump then
		upY += 1
	end
	if flyDownHeld then
		upY -= 1
	end

	local velocity = Vector3.new(horizontal.X, upY, horizontal.Z)
	if velocity.Magnitude > 1 then
		velocity = velocity.Unit
	end

	flyBV.Velocity = velocity * flySpeed
	flyBG.CFrame = CFrame.new(hrp.Position, hrp.Position + camCF.LookVector)
end


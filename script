--========================
-- ESP LOGIC (local only)
--========================
local function destroyESPForPlayer(plr)
	local data = espObjects[plr]
	if not data then return end

	if data.charConn then data.charConn:Disconnect() end
	if data.ancestryConn then data.ancestryConn:Disconnect() end
	if data.highlight then data.highlight:Destroy() end
	if data.billboard then data.billboard:Destroy() end

	espObjects[plr] = nil
end

local function getHumanoid(character)
	return character and character:FindFirstChildOfClass("Humanoid")
end

local function getHRP(character)
	return character and character:FindFirstChild("HumanoidRootPart")
end

local function createESPForPlayer(plr)
	if plr == LocalPlayer then return end
	destroyESPForPlayer(plr)

	local character = plr.Character
	if not character then return end

	local hrp = getHRP(character)
	if not hrp then return end

	local data = {}
	espObjects[plr] = data

	-- Highlight
	local hl = Instance.new("Highlight")
	hl.Name = "LocalESP_Highlight"
	hl.Adornee = character
	hl.FillColor = Color3.fromRGB(255, 235, 120)
	hl.FillTransparency = 0.65
	hl.OutlineColor = Color3.fromRGB(255, 255, 255)
	hl.OutlineTransparency = 0
	hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
	hl.Enabled = false
	hl.Parent = screenGui
	data.highlight = hl

	-- Billboard NameTag
	local bill = Instance.new("BillboardGui")
	bill.Name = "LocalESP_Billboard"
	bill.Adornee = hrp
	bill.Size = UDim2.new(0, 180, 0, 46)
	bill.StudsOffset = Vector3.new(0, 3.4, 0)
	bill.AlwaysOnTop = true
	bill.MaxDistance = 500
	bill.Enabled = false
	bill.Parent = screenGui
	data.billboard = bill

	local bg = Instance.new("Frame")
	bg.Size = UDim2.new(1, 0, 1, 0)
	bg.BackgroundColor3 = Color3.fromRGB(25, 28, 38)
	bg.BackgroundTransparency = 0.15
	bg.Parent = bill
	addCorner(bg, 12)
	addStroke(bg, Color3.fromRGB(255, 255, 255), 1)

	local nameText = createLabel(bg, plr.Name, UDim2.new(1, -8, 0, 20), UDim2.new(0, 4, 0, 2), Enum.Font.GothamBold, 14, COLORS.Text, 1)
	nameText.TextXAlignment = Enum.TextXAlignment.Center

	local infoText = createLabel(bg, "", UDim2.new(1, -8, 0, 18), UDim2.new(0, 4, 0, 22), Enum.Font.Gotham, 12, COLORS.SubText, 1)
	infoText.TextXAlignment = Enum.TextXAlignment.Center

	data.nameText = nameText
	data.infoText = infoText

	data.ancestryConn = character.AncestryChanged:Connect(function(_, parent)
		if parent == nil then
			if data.highlight then data.highlight.Enabled = false end
			if data.billboard then data.billboard.Enabled = false end
		end
	end)

	data.charConn = plr.CharacterAdded:Connect(function()
		task.wait(0.25)
		createESPForPlayer(plr)
	end)
end

local function rebuildESP()
	for plr, _ in pairs(espObjects) do
		destroyESPForPlayer(plr)
	end
	for _, plr in ipairs(Players:GetPlayers()) do
		if plr ~= LocalPlayer then
			createESPForPlayer(plr)
		end
	end
end

local function updateESP()
	local myChar = LocalPlayer.Character
	local myHRP = myChar and myChar:FindFirstChild("HumanoidRootPart")

	for _, plr in ipairs(Players:GetPlayers()) do
		if plr ~= LocalPlayer then
			if not espObjects[plr] then
				createESPForPlayer(plr)
			end

			local data = espObjects[plr]
			if data then
				local char = plr.Character
				local hum = getHumanoid(char)
				local hrp = getHRP(char)

				local alive = hum and hum.Health > 0 and hrp ~= nil and char ~= nil

				if data.highlight then
					data.highlight.Enabled = (espEnabled and espHighlightsEnabled and alive) or false
					if alive then
						data.highlight.Adornee = char
					end
				end

				if data.billboard then
					data.billboard.Enabled = (espEnabled and espNameTagsEnabled and alive) or false
					if alive then
						data.billboard.Adornee = hrp
					end
				end

				if data.infoText then
					if alive then
						local distText = "?"
						if myHRP then
							local dist = (myHRP.Position - hrp.Position).Magnitude
							distText = tostring(math.floor(dist + 0.5)) .. " studs"
						end

						if espShowHealth and hum then
							data.infoText.Text = ("HP %d/%d  •  %s"):format(math.floor(hum.Health + 0.5), math.floor(hum.MaxHealth + 0.5), distText)
						else
							data.infoText.Text = distText
						end
					else
						data.infoText.Text = ""
					end
				end

				if data.nameText then
					data.nameText.Text = plr.DisplayName
				end
			end
		end
	end
end

rebuildBtn.MouseButton1Click:Connect(function()
	rebuildESP()
end)

Players.PlayerAdded:Connect(function(plr)
	if plr ~= LocalPlayer then
		task.wait(0.2)
		createESPForPlayer(plr)
		populateList()
	end
end)

Players.PlayerRemoving:Connect(function(plr)
	destroyESPForPlayer(plr)
	populateList()
end)

heartbeatConn = RunService.Heartbeat:Connect(function()
	updateESP()
end)


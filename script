--========================
-- WALK SPEED LOGIC
--========================
local function clamp(n, a, b)
	if n < a then return a end
	if n > b then return b end
	return n
end

local function applyWalkSpeed()
	local char = LocalPlayer.Character
	if not char then return end
	local hum = char:FindFirstChildOfClass("Humanoid")
	if hum then
		hum.WalkSpeed = currentWalkSpeed
	end
end

local function speedToAlpha(speed)
	return (speed - MIN_WALKSPEED) / (MAX_WALKSPEED - MIN_WALKSPEED)
end

local function alphaToSpeed(alpha)
	local raw = MIN_WALKSPEED + alpha * (MAX_WALKSPEED - MIN_WALKSPEED)
	return math.floor(raw + 0.5)
end

local function updateSpeedSliderVisuals()
	local alpha = speedToAlpha(currentWalkSpeed)
	alpha = clamp(alpha, 0, 1)

	sliderFill.Size = UDim2.new(alpha, 0, 1, 0)
	sliderKnob.Position = UDim2.new(alpha, -11, 0.5, -11)
	speedValueLabel.Text = tostring(currentWalkSpeed)
end

local function setWalkSpeed(newSpeed)
	currentWalkSpeed = clamp(math.floor(newSpeed + 0.5), MIN_WALKSPEED, MAX_WALKSPEED)
	updateSpeedSliderVisuals()
	applyWalkSpeed()
end

local function setSpeedFromInputPosition(inputPosX)
	local trackAbsPos = sliderTrack.AbsolutePosition.X
	local trackAbsSize = sliderTrack.AbsoluteSize.X
	if trackAbsSize <= 0 then return end

	local alpha = (inputPosX - trackAbsPos) / trackAbsSize
	alpha = clamp(alpha, 0, 1)
	setWalkSpeed(alphaToSpeed(alpha))
end


local function clamp(n, a, b)
	if n < a then return a end
	if n > b then return b end
	return n
end

local function addCorner(inst, radius)
	local c = Instance.new("UICorner")
	c.CornerRadius = UDim.new(0, radius or 10)
	c.Parent = inst
	return c
end

local function addStroke(inst, color, thickness, transparency)
	local s = Instance.new("UIStroke")
	s.Color = color or COLORS.Stroke
	s.Thickness = thickness or 2
	s.Transparency = transparency or 0
	s.Parent = inst
	return s
end

local function addGradient(inst, c1, c2, rot)
	local g = Instance.new("UIGradient")
	g.Color = ColorSequence.new(c1, c2)
	g.Rotation = rot or 90
	g.Parent = inst
	return g
end

local function createLabel(parent, text, size, pos, font, textSize, color, transparency)
	local l = Instance.new("TextLabel")
	l.BackgroundTransparency = transparency == nil and 1 or transparency
	l.Size = size
	l.Position = pos
	l.Text = text or ""
	l.Font = font or Enum.Font.GothamBold
	l.TextSize = textSize or 16
	l.TextColor3 = color or COLORS.Text
	l.TextXAlignment = Enum.TextXAlignment.Left
	l.TextYAlignment = Enum.TextYAlignment.Center
	l.Parent = parent
	return l
end

local function createButton(parent, text, size, pos, bgColor)
	local b = Instance.new("TextButton")
	b.Size = size
	b.Position = pos
	b.Text = text
	b.Font = Enum.Font.GothamBold
	b.TextSize = 15
	b.TextColor3 = COLORS.Text
	b.BackgroundColor3 = bgColor or COLORS.Button
	b.AutoButtonColor = false
	b.Parent = parent
	addCorner(b, 12)
	addStroke(b, COLORS.Stroke, 2)
	addGradient(b, Color3.fromRGB(245,250,255), b.BackgroundColor3, 90)

	b.MouseEnter:Connect(function()
		b.BackgroundColor3 = COLORS.ButtonHover
	end)
	b.MouseLeave:Connect(function()
		if b.Parent then
			b.BackgroundColor3 = bgColor or COLORS.Button
		end
	end)

	return b
end

local function createPanel(parent, size, pos, color)
	local f = Instance.new("Frame")
	f.Size = size
	f.Position = pos
	f.BackgroundColor3 = color or COLORS.Panel
	f.Parent = parent
	addCorner(f, 12)
	addStroke(f, COLORS.Stroke, 2)
	return f
end

local function createToggleRow(parent, y, labelText, defaultValue, onChanged, small)
	local row = Instance.new("Frame")
	row.Name = labelText:gsub("%s+","").."Row"
	row.Size = UDim2.new(1, -8, 0, small and 40 or 46)
	row.Position = UDim2.new(0, 4, 0, y)
	row.BackgroundColor3 = COLORS.Panel2
	row.Parent = parent
	addCorner(row, 12)
	addStroke(row, COLORS.Stroke, 2)

	local lbl = createLabel(
		row,
		labelText,
		UDim2.new(1, -90, 1, 0),
		UDim2.new(0, 12, 0, 0),
		Enum.Font.GothamBold,
		small and 13 or 15,
		COLORS.Text,
		1
	)

	local toggle = Instance.new("TextButton")
	toggle.Size = UDim2.new(0, 62, 0, 26)
	toggle.Position = UDim2.new(1, -74, 0.5, -13)
	toggle.Text = ""
	toggle.BackgroundColor3 = defaultValue and COLORS.Green or Color3.fromRGB(150, 160, 180)
	toggle.AutoButtonColor = false
	toggle.Parent = row
	addCorner(toggle, 999)
	addStroke(toggle, COLORS.Stroke, 2)

	local knob = Instance.new("Frame")
	knob.Size = UDim2.new(0, 22, 0, 22)
	knob.Position = defaultValue and UDim2.new(1, -24, 0.5, -11) or UDim2.new(0, 2, 0.5, -11)
	knob.BackgroundColor3 = COLORS.White
	knob.Parent = toggle
	addCorner(knob, 999)
	addStroke(knob, Color3.fromRGB(220,220,220), 1)

	local value = defaultValue
	local function setValue(v)
		value = v
		toggle.BackgroundColor3 = value and COLORS.Green or Color3.fromRGB(150,160,180)
		knob.Position = value and UDim2.new(1, -24, 0.5, -11) or UDim2.new(0, 2, 0.5, -11)
		if onChanged then onChanged(value) end
	end

	toggle.MouseButton1Click:Connect(function()
		setValue(not value)
	end)

	return {
		Row = row,
		Get = function() return value end,
		Set = setValue,
	}
end

local function createSliderRow(parent, y, titleText, minVal, maxVal, startVal, onChanged, small)
	local rowH = small and 66 or 74
	local row = Instance.new("Frame")
	row.Name = titleText:gsub("%s+","").."Slider"
	row.Size = UDim2.new(1, -8, 0, rowH)
	row.Position = UDim2.new(0, 4, 0, y)
	row.BackgroundColor3 = COLORS.Panel2
	row.Parent = parent
	addCorner(row, 12)
	addStroke(row, COLORS.Stroke, 2)

	local title = createLabel(row, titleText, UDim2.new(0.6, 0, 0, 22), UDim2.new(0, 10, 0, 4), Enum.Font.GothamBlack, small and 13 or 14, COLORS.SubText, 1)
	local valueLabel = createLabel(row, tostring(startVal), UDim2.new(0.35, 0, 0, 22), UDim2.new(1, -90, 0, 4), Enum.Font.GothamBlack, small and 13 or 14, COLORS.Text, 1)
	valueLabel.TextXAlignment = Enum.TextXAlignment.Right

	local trackHolder = Instance.new("Frame")
	trackHolder.Size = UDim2.new(1, -20, 0, 24)
	trackHolder.Position = UDim2.new(0, 10, 0, 26)
	trackHolder.BackgroundTransparency = 1
	trackHolder.Parent = row

	local track = Instance.new("Frame")
	track.Size = UDim2.new(1, 0, 0, 10)
	track.Position = UDim2.new(0, 0, 0.5, -5)
	track.BackgroundColor3 = COLORS.SliderTrack
	track.Parent = trackHolder
	addCorner(track, 999)
	addStroke(track, COLORS.Stroke, 1)

	local fill = Instance.new("Frame")
	fill.Size = UDim2.new(0, 0, 1, 0)
	fill.BackgroundColor3 = COLORS.SliderFill
	fill.Parent = track
	addCorner(fill, 999)

	local knob = Instance.new("Frame")
	knob.Size = UDim2.new(0, 20, 0, 20)
	knob.Position = UDim2.new(0, -10, 0.5, -10)
	knob.BackgroundColor3 = COLORS.White
	knob.Parent = trackHolder
	addCorner(knob, 999)
	addStroke(knob, COLORS.Stroke, 2)

	local inputCatcher = Instance.new("TextButton")
	inputCatcher.Size = UDim2.new(1, 0, 1, 0)
	inputCatcher.BackgroundTransparency = 1
	inputCatcher.Text = ""
	inputCatcher.AutoButtonColor = false
	inputCatcher.Parent = trackHolder

	local minLbl = createLabel(row, tostring(minVal), UDim2.new(0, 40, 0, 14), UDim2.new(0, 10, 1, -18), Enum.Font.Gotham, 11, COLORS.SubText, 1)
	local maxLbl = createLabel(row, tostring(maxVal), UDim2.new(0, 40, 0, 14), UDim2.new(1, -50, 1, -18), Enum.Font.Gotham, 11, COLORS.SubText, 1)
	maxLbl.TextXAlignment = Enum.TextXAlignment.Right

	local dragging = false
	local value = startVal

	local function valueToAlpha(v)
		return (v - minVal) / (maxVal - minVal)
	end

	local function alphaToValue(a)
		local raw = minVal + a * (maxVal - minVal)
		return math.floor(raw + 0.5)
	end

	local function redraw()
		local alpha = clamp(valueToAlpha(value), 0, 1)
		fill.Size = UDim2.new(alpha, 0, 1, 0)
		knob.Position = UDim2.new(alpha, -10, 0.5, -10)
		valueLabel.Text = tostring(value)
	end

	local function setValue(v)
		value = clamp(math.floor(v + 0.5), minVal, maxVal)
		redraw()
		if onChanged then onChanged(value) end
	end

	local function setFromInputX(x)
		local ax = track.AbsolutePosition.X
		local aw = track.AbsoluteSize.X
		if aw <= 0 then return end
		local alpha = clamp((x - ax) / aw, 0, 1)
		setValue(alphaToValue(alpha))
	end

	inputCatcher.InputBegan:Connect(function(input)
		local t = input.UserInputType
		if t == Enum.UserInputType.MouseButton1 or t == Enum.UserInputType.Touch then
			dragging = true
			setFromInputX(input.Position.X)
		end
	end)

	inputCatcher.InputEnded:Connect(function(input)
		local t = input.UserInputType
		if t == Enum.UserInputType.MouseButton1 or t == Enum.UserInputType.Touch then
			dragging = false
		end
	end)

	UserInputService.InputChanged:Connect(function(input)
		if not dragging then return end
		if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
			setFromInputX(input.Position.X)
		end
	end)

	redraw()

	return {
		Row = row,
		Get = function() return value end,
		Set = setValue,
	}
end

local function getCharacter()
